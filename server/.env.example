# PupilMetrics License Server — Environment Configuration
# Copy this to .env and fill in your values. Never commit .env to git.

# HTTP port
PORT=8080

# Shared secret between app and server.
# Must match _apiSecret in lib/utils/license_manager.dart.
# Generate with: openssl rand -hex 32
PM_API_SECRET=change-me-to-a-random-32-plus-char-string

# Admin API secret — used for /admin/* endpoints only. Keep very secure.
# Generate with: openssl rand -hex 32
PM_ADMIN_SECRET=change-me-to-a-different-random-32-plus-char-string

# License HMAC secret — must match _secretKey in lib/utils/license_manager.dart.
PM_LICENSE_SECRET=J7hhJkReFF-CNRI-2026-JPz123Z883!

# Path to the JSON license database (relative to where you run the server).
PM_DB_PATH=data/licenses.json
