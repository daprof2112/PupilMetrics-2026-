  Widget _buildChartAssetOverlay({
    required String chartPreset,
    required bool isRightEye,
  }) {
    final preset = chartPreset.toLowerCase();
    final side = isRightEye ? 'od' : 'os';

    final candidates = <String>[
      'assets/charts/${preset}_${side}_mask.png',
      'assets/charts/${preset}_${side}_overlay.png',
      'assets/charts/${preset}_${side}.png',
      'assets/charts/${preset}_mask.png',
      'assets/charts/${preset}_overlay.png',
      'assets/charts/${preset}.png',
      // Legacy names if copied from generated probe output.
      'assets/charts/${preset.toUpperCase()}_${isRightEye ? 'PR' : 'LEV'}_mask_whole.png',
      'assets/charts/${preset.toUpperCase()}_${isRightEye ? 'PR' : 'LEV'}_gray_whole.png',
    ];

    return Center(
      child: TweenAnimationBuilder<double>(
        tween: Tween(begin: 0, end: 0.32),
        duration: const Duration(milliseconds: 150),
        builder: (_, opacity, __) => Opacity(
          opacity: opacity,
          child: ColorFiltered(
            colorFilter: const ColorFilter.mode(Colors.white, BlendMode.srcIn),
            child: Image.asset(
              candidates.first,
              fit: BoxFit.contain,
              errorBuilder: (_, __, ___) {
                if (candidates.length == 1) {
                  return const SizedBox.shrink();
                }
                return _buildFallbackChartAsset(candidates.sublist(1));
              },
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildFallbackChartAsset(List<String> candidates) {
    if (candidates.isEmpty) return const SizedBox.shrink();

    return Image.asset(
      candidates.first,
      fit: BoxFit.contain,
      errorBuilder: (_, __, ___) => _buildFallbackChartAsset(candidates.sublist(1)),
    );
  }

