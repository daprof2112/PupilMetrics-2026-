  String _generateTxtReport() {
    final l10n = AppLocalizations.of(context)!;
    final loc = PupilAnalyzerLocalizations(l10n);
    final b = StringBuffer();
    b.writeln('=' * 60);
    b.writeln('  CNRI PUPIL ANALYSIS REPORT v5.3.0 - RESEARCH VERSION');
    b.writeln('=' * 60);
    b.writeln('\nDISCLAIMER: Research/Educational Tool Only');
    b.writeln('Results are research observations, NOT medical diagnoses.');
    b.writeln('=' * 60);
    b.writeln('\nDate: ${DateFormat('MMMM dd, yyyy HH:mm').format(DateTime.now())}');
    b.writeln('\n--- PERSON INFORMATION ---');
    b.writeln('Name: ${widget.patientInfo.name}');
    b.writeln('Sex: ${widget.patientInfo.sexString}');
    b.writeln('Age: ${widget.patientInfo.age} years');
    b.writeln('Age Group: ${_ageNormResult?.ageGroup ?? "N/A"}');
    if (widget.patientInfo.mainComplaints?.isNotEmpty ?? false) b.writeln('Complaints: ${widget.patientInfo.mainComplaints}');

    if (_anisocoriaResult != null) {
      b.writeln('\n--- PUPIL SIZE COMPARISON ---');
      b.writeln('OD: ${_anisocoriaResult!.rightPupilRatio.toStringAsFixed(2)}%');
      b.writeln('OS: ${_anisocoriaResult!.leftPupilRatio.toStringAsFixed(2)}%');
      b.writeln('Diff: ${_anisocoriaResult!.absoluteDifference.toStringAsFixed(2)}%');
      b.writeln('Severity: ${_anisocoriaResult!.severity.name}');
    }

    if (_irisMetrics?.odIrisDiameterPx != null) {
      b.writeln('\n--- CAPTURE DISTANCE METRICS ---');
      b.writeln('OD Iris: ${_irisMetrics!.odIrisDiameterPx?.toStringAsFixed(0)}px');
      b.writeln('OS Iris: ${_irisMetrics!.osIrisDiameterPx?.toStringAsFixed(0)}px');
      b.writeln('Match: ${_irisMetrics!.sizeMatchPercent?.toStringAsFixed(1)}%');
      b.writeln('Status: ${_irisMetrics!.distanceMatchStatus}');
    }

    if (_rightResult != null) { b.writeln('\n--- RIGHT EYE (OD) ---'); _writeEyeTxt(b, _rightResult!, true, loc, l10n); }
    if (_leftResult != null) { b.writeln('\n--- LEFT EYE (OS) ---'); _writeEyeTxt(b, _leftResult!, false, loc, l10n); }

    b.writeln('\n--- RESEARCH OBSERVATIONS ---');
    _writeObsTxt(b, loc, l10n);
    b.writeln('\n${'=' * 60}\nEND OF REPORT\n${'=' * 60}');
    return b.toString();
  }

  void _writeEyeTxt(StringBuffer b, EyeAnalysisResult r, bool isRight, PupilAnalyzerLocalizations loc, AppLocalizations l10n) {
    final eyeCode = isRight ? 'D' : 'S';

    b.writeln('Grade: ${r.qualityGrade}');
    b.writeln('P/I Ratio: ${r.pupilIrisRatio.toStringAsFixed(2)}%');
    b.writeln('Ellipseness: ${r.ellipseness.toStringAsFixed(2)}%');
    b.writeln('Circularity: ${r.circularityScore.toStringAsFixed(2)}%');
    b.writeln('Decentralization: ${r.decentralization.toStringAsFixed(2)}%');

    if (r.ellipseAssessment != null) {
      b.writeln('\nPUPIL FORM: ${loc.getFormTypeName(r.ellipseAssessment!.formType)}');
      b.writeln('  ${loc.getPupilFormDescription(r.ellipseAssessment!.formType)}');
    }

    if (r.decentrationAssessment != null && r.decentrationAssessment!.pattern != DecentrationPattern.centered) {
      b.writeln('\nDECENTRATION: ${loc.getPatternName(r.decentrationAssessment!.pattern)} (${r.decentralization.toStringAsFixed(2)}%)');
      b.writeln('  ${loc.getDecentrationDescription(r.decentrationAssessment!.pattern, isRight)}');
    }

    if (r.flattenings.isNotEmpty) {
      b.writeln('\nFLATTENINGS:');
      for (final f in r.flattenings) {
        b.writeln('  - ${loc.getZoneName(f.zone)} (${f.clockPosition}): ${f.percentage.toStringAsFixed(2)}%');
        b.writeln('    ${loc.getFlatteningDescription(f.zone, isRight)}');
      }
    }

    if (r.protrusions.isNotEmpty) {
      b.writeln('\nPROTRUSIONS:');
      for (final p in r.protrusions) {
        b.writeln('  - ${loc.getZoneName(p.zone)} (${p.clockPosition}): ${p.percentage.toStringAsFixed(2)}%');
        b.writeln('    ${loc.getProtrusionDescription(p.zone, isRight)}');
      }
    }

    // v5.3.0: FULL ANW SECTION (Bexel-compatible)
    if (r.anwAssessment != null) {
      final anw = r.anwAssessment!;
      b.writeln('\nPARAMETERS OF THE AUTONOMIC NERVE WREATH (ANW):');
      b.writeln('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
      b.writeln('Diameter: ${anw.diameterPx.toStringAsFixed(0)} px');
      b.writeln('Perimeter: ${anw.perimeterPx.toStringAsFixed(0)} px');
      b.writeln('');
      b.writeln('Ratio: ${anw.ratio.toStringAsFixed(1)}%'.padRight(28) + anw.ratioStatusLabel);
      b.writeln('Asymmetry: ${anw.asymmetryPercent.toStringAsFixed(1)}%'.padRight(28) + (anw.isAsymmetryNormal ? 'Normal' : 'Elevated'));
      b.writeln('Form Type: ${anw.formTypeName}'.padRight(28) + (anw.isFormNormal ? 'Normal' : 'Abnormal'));

      // Tonic state
      if (anw.tonicState != null) {
        b.writeln('\nTonic State: ${anw.tonicState}');
        if (anw.tonicStateDescription.isNotEmpty) {
          b.writeln('  ${anw.tonicStateDescription}');
        }
      }

      // Findings
      if (anw.bexelFindings.isNotEmpty) {
        b.writeln('\nFindings:');
        for (final finding in anw.bexelFindings) {
          b.writeln('  $finding');
        }
      }

      // Shift details
      if (anw.hasShift && anw.primaryShift != null) {
        b.writeln('\nSHIFT DETECTED:');
        b.writeln('  $eyeCode: ${anw.primaryShift!.zoneName} shift (${anw.primaryShift!.clockPosition})');
        if (anw.primaryShift!.clinicalAssociation.isNotEmpty) {
          b.writeln('  Clinical: ${anw.primaryShift!.clinicalAssociation}');
        }
      }

      // Constriction details
      if (anw.hasConstrictions) {
        b.writeln('\nCONSTRICTION DETECTED:');
        b.writeln('  $eyeCode: ${anw.constrictionString}');
      }
    }

    b.writeln('\nConfidence: ${(r.confidence * 100).toStringAsFixed(0)}%');
  }

  void _writeObsTxt(StringBuffer b, PupilAnalyzerLocalizations loc, AppLocalizations l10n) {
    for (final entry in [(_rightResult, 'D', true), (_leftResult, 'S', false)]) {
      final r = entry.$1; final code = entry.$2; final isRight = entry.$3;
      if (r == null) continue;

      for (final f in r.flattenings.where((f) => f.percentage >= 3))
        b.writeln('$code : ${loc.getZoneName(f.zone)} flattening (${f.clockPosition}) - ${f.percentage.toStringAsFixed(2)}%');
      for (final p in r.protrusions.where((p) => p.percentage >= 1))
        b.writeln('$code : ${loc.getZoneName(p.zone)} protrusion (${p.clockPosition}) - ${p.percentage.toStringAsFixed(2)}%');
      if (r.decentrationAssessment != null && r.decentrationAssessment!.pattern != DecentrationPattern.centered)
        b.writeln('$code : ${loc.getPatternName(r.decentrationAssessment!.pattern)}.');
      if (r.ellipseAssessment != null)
        b.writeln('$code : ${r.ellipseAssessment!.formType == PupilFormType.circle ? "Normal pupil form" : "${loc.getFormTypeName(r.ellipseAssessment!.formType)} pupil form"}.');

      // v5.3.0: Add ANW findings to observations
      if (r.anwAssessment != null) {
        final anw = r.anwAssessment!;
        if (!anw.isRatioNormal) {
          b.writeln('$code : ANW ratio ${anw.ratioStatusLabel.toLowerCase()} (${anw.ratio.toStringAsFixed(1)}%) - ${anw.tonicState ?? ""}.');
        }
        for (final finding in anw.bexelFindings) {
          b.writeln(finding);
        }
      }
    }

    if (_anisocoriaResult != null && _anisocoriaResult!.severity != AnisocoriaSeverity.none) {
      final larger = _anisocoriaResult!.largerPupil == 'Right (OD)' ? 'D' : 'S';
      b.writeln('ANISOCORIA ($larger>${larger == 'D' ? 'S' : 'D'}) = ${_anisocoriaResult!.absoluteDifference.toStringAsFixed(0)}%.');
    }

    // v5.3.0: Bilateral ANW comparison
    if (_rightResult?.anwAssessment != null && _leftResult?.anwAssessment != null) {
      final odAnw = _rightResult!.anwAssessment!;
      final osAnw = _leftResult!.anwAssessment!;
      final anwDiff = (odAnw.ratio - osAnw.ratio).abs();
      if (anwDiff > 5) {
        b.writeln('ANW ASYMMETRY: OD=${odAnw.ratio.toStringAsFixed(1)}% vs OS=${osAnw.ratio.toStringAsFixed(1)}% (${anwDiff.toStringAsFixed(1)}% diff).');
      }
      // Check for functional frustration pattern
      if ((odAnw.ratioStatus == ANWRatioStatus.spastic && osAnw.ratioStatus == ANWRatioStatus.atonic) ||
          (odAnw.ratioStatus == ANWRatioStatus.atonic && osAnw.ratioStatus == ANWRatioStatus.spastic)) {
        b.writeln('BILATERAL PATTERN: Functional frustration in correlation between sympathetic and parasympathetic nervous systems.');
      }
    }
  }

