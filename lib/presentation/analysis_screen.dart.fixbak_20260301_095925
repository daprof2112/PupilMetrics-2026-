        pw.Container(padding: const pw.EdgeInsets.symmetric(horizontal: 8, vertical: 4), color: r.qualityGrade == 'A' ? PdfColors.green : (r.qualityGrade == 'B' ? PdfColors.orange : PdfColors.red), child: pw.Text('Grade ${r.qualityGrade}', style: const pw.TextStyle(color: PdfColors.white, fontSize: 10)))
      ]),
      pw.SizedBox(height: 8),
      pw.Row(children: [
        pw.Expanded(child: pw.Column(crossAxisAlignment: pw.CrossAxisAlignment.start, children: [
          pw.Text('P/I Ratio: ${r.pupilIrisRatio.toStringAsFixed(1)}%${ml != null ? " (ML: ${ml.piRatio.toStringAsFixed(1)}%)" : ""}', style: const pw.TextStyle(fontSize: 10)),
